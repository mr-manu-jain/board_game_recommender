aborative parts\n","        self.user_embed = nn.Embedding(num_users, hidden_dim)\n","        self.item_embed = nn.Embedding(num_items, hidden_dim)\n","\n","        # Hybrid MLP\n","        # Input: User Latent + Item Latent + Item LLM Embedding\n","        input_dim = hidden_dim + hidden_dim + llm_dim\n","        self.mlp = nn.Sequential(\n","            nn.Linear(input_dim, 256),\n","            nn.ReLU(),\n","            nn.Dropout(0.2),\n","            nn.Linear(256, 64),\n","            nn.ReLU(),\n","            nn.Linear(64, 1) # Rating prediction\n","        )\n","\n","    def forward(self, user_ids, item_ids, item_llm_embs):\n","        u_feat = self.user_embed(user_ids)\n","        i_feat = self.item_embed(item_ids)\n","\n","        combined = torch.cat([u_feat, i_feat, item_llm_embs], dim=1)\n","        return self.mlp(combined).squeeze()"]}]}